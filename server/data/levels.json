[
  { "id": 1, "title": "1. Scânteia (The Spark)", "difficulty": "Ușor", "description": "Conectează direct sursa de energie la bec.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 200 }], "gates": [], "target": { "id": "B1", "x": 600, "y": 200 } } },
  { "id": 2, "title": "2. Inversia (The Inverter)", "difficulty": "Ușor", "description": "Folosește poarta NOT. Becul trebuie să se aprindă când switch-ul este OFF.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 200 }], "gates": [{ "id": "G1", "type": "NOT", "x": 350, "y": 200 }], "target": { "id": "B1", "x": 600, "y": 200 } } },
  { "id": 3, "title": "3. Acordul (The AND Gate)", "difficulty": "Ușor", "description": "Poarta AND are nevoie de ambele semnale pentru a lăsa curentul să treacă.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 150 }, { "id": "S2", "label": "B", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "AND", "x": 350, "y": 200 }], "target": { "id": "B1", "x": 600, "y": 200 } } },
  { "id": 4, "title": "4. Alternativa (The OR Gate)", "difficulty": "Ușor", "description": "Poarta OR se activează dacă măcar un switch este ON.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 150 }, { "id": "S2", "label": "B", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "OR", "x": 350, "y": 200 }], "target": { "id": "B1", "x": 600, "y": 200 } } },
  { "id": 5, "title": "5. Exclusivitate (The XOR Gate)", "difficulty": "Mediu", "description": "Poarta XOR (Exclusive OR) se aprinde DOAR dacă stările switch-urilor sunt diferite.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 150 }, { "id": "S2", "label": "B", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "XOR", "x": 350, "y": 200 }], "target": { "id": "B1", "x": 600, "y": 200 } } },
  { "id": 6, "title": "6. Siguranța (NAND Logic)", "difficulty": "Mediu", "description": "Construiește o poartă NAND: combină un AND cu un NOT.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 150 }, { "id": "S2", "label": "B", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "AND", "x": 300, "y": 200 }, { "id": "G2", "type": "NOT", "x": 450, "y": 200 }], "target": { "id": "B1", "x": 650, "y": 200 } } },
  { "id": 7, "title": "7. Triunghiul (3 Inputs)", "difficulty": "Mediu", "description": "Aprinde becul folosind cele 3 surse. Toate trebuie să fie conectate corect.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 50, "y": 100 }, { "id": "S2", "label": "B", "x": 50, "y": 200 }, { "id": "S3", "label": "C", "x": 50, "y": 300 }], "gates": [{ "id": "G1", "type": "AND", "x": 250, "y": 150 }, { "id": "G2", "type": "OR", "x": 450, "y": 220 }], "target": { "id": "B1", "x": 650, "y": 220 } } },
  { "id": 8, "title": "8. Niciuna (NOR Logic)", "difficulty": "Mediu", "description": "Becul trebuie să fie aprins doar când ambele switch-uri sunt OFF.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 150 }, { "id": "S2", "label": "B", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "OR", "x": 300, "y": 200 }, { "id": "G2", "type": "NOT", "x": 450, "y": 200 }], "target": { "id": "B1", "x": 650, "y": 200 } } },
  { "id": 9, "title": "9. Sistem Parola (The Passcode)", "difficulty": "Greu", "description": "Codul este: ON, OFF, ON. Găsește combinația de porți care aprinde becul DOAR la această parolă.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 50, "y": 100 }, { "id": "S2", "label": "B", "x": 50, "y": 200 }, { "id": "S3", "label": "C", "x": 50, "y": 300 }], "gates": [{ "id": "G1", "type": "NOT", "x": 250, "y": 200 }, { "id": "G2", "type": "AND", "x": 400, "y": 150 }, { "id": "G3", "type": "AND", "x": 550, "y": 220 }], "target": { "id": "B1", "x": 750, "y": 220 } } },
  { "id": 10, "title": "10. Detectivul (Odd One Out)", "difficulty": "Greu", "description": "Avem 3 switch-uri. Aprinde becul DOAR când un număr impar de switch-uri sunt activate.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 50, "y": 100 }, { "id": "S2", "label": "B", "x": 50, "y": 200 }, { "id": "S3", "label": "C", "x": 50, "y": 300 }], "gates": [{ "id": "G1", "type": "XOR", "x": 250, "y": 150 }, { "id": "G2", "type": "XOR", "x": 450, "y": 220 }], "target": { "id": "B1", "x": 650, "y": 220 } } },
  { "id": 11, "title": "11. Multiplexorul Simplu", "difficulty": "Expert", "description": "Dacă C=0, trece semnalul A. Dacă C=1, trece semnalul B.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 50, "y": 100 }, { "id": "S2", "label": "B", "x": 50, "y": 200 }, { "id": "S3", "label": "C(Sel)", "x": 50, "y": 350 }], "gates": [{ "id": "G1", "type": "NOT", "x": 200, "y": 350 }, { "id": "G2", "type": "AND", "x": 350, "y": 150 }, { "id": "G3", "type": "AND", "x": 350, "y": 250 }, { "id": "G4", "type": "OR", "x": 550, "y": 200 }], "target": { "id": "B1", "x": 750, "y": 200 } } },
  { "id": 12, "title": "12. Comparatorul de Egalitate", "difficulty": "Expert", "description": "Aprinde becul DOAR dacă A și B au aceeași stare (amândouă ON sau amândouă OFF).", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 100, "y": 150 }, { "id": "S2", "label": "B", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "XOR", "x": 300, "y": 200 }, { "id": "G2", "type": "NOT", "x": 450, "y": 200 }], "target": { "id": "B1", "x": 650, "y": 200 } } },
  { "id": 13, "title": "13. Sistem Alarmă Majoritar", "difficulty": "Expert", "description": "Din 3 senzori, alarma (becul) sună doar dacă CEL PUȚIN 2 sunt activi.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 50, "y": 100 }, { "id": "S2", "label": "B", "x": 50, "y": 200 }, { "id": "S3", "label": "C", "x": 50, "y": 300 }], "gates": [{ "id": "G1", "type": "AND", "x": 250, "y": 100 }, { "id": "G2", "type": "AND", "x": 250, "y": 200 }, { "id": "G3", "type": "AND", "x": 250, "y": 300 }, { "id": "G4", "type": "OR", "x": 450, "y": 150 }, { "id": "G5", "type": "OR", "x": 600, "y": 200 }], "target": { "id": "B1", "x": 750, "y": 200 } } },
  { "id": 14, "title": "14. Half-Adder (Partea de Sumă)", "difficulty": "Master", "description": "Calculează bitul de sumă a două numere binare folosind ce ai învățat la nivelul 5.", "setup": { "switches": [{ "id": "S1", "label": "Bit 1", "x": 100, "y": 150 }, { "id": "S2", "label": "Bit 2", "x": 100, "y": 250 }], "gates": [{ "id": "G1", "type": "XOR", "x": 350, "y": 200 }], "target": { "id": "B1", "x": 600, "y": 200 } } },
  { "id": 15, "title": "15. The Final Challenge", "difficulty": "Master", "description": "Combină un XOR cu alte elemente pentru a crea o capcană logică unde doar o singură manetă (A sau B) poate fi trasă, dar C trebuie să o oprească mereu.", "setup": { "switches": [{ "id": "S1", "label": "A", "x": 50, "y": 100 }, { "id": "S2", "label": "B", "x": 50, "y": 200 }, { "id": "S3", "label": "C", "x": 50, "y": 350 }], "gates": [{ "id": "G1", "type": "XOR", "x": 250, "y": 150 }, { "id": "G2", "type": "NOT", "x": 250, "y": 350 }, { "id": "G3", "type": "AND", "x": 450, "y": 250 }], "target": { "id": "B1", "x": 650, "y": 250 } } }
]